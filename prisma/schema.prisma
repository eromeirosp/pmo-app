generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id               String           @id @default(uuid())
  name             String
  manager          String
  budget           Float
  stakeholders     String?
  status           String           @default("GREEN")
  classification   String?
  problems         String?
  returns          String?
  impacts              String?
  preliminaryTimeline  String?
  milestones           String?
  successCriteria      String?
  createdAt            DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  department       String?
  description      String?
  charterApproved    Boolean          @default(false)
  charterApprovedAt  DateTime?
  closingApproved    Boolean          @default(false)
  closingApprovedAt  DateTime?
  closingReopenReason String?
  currency             String           @default("BRL")
  statusOverride       String?
  statusOverrideReason String?
  expectedReturn   Float?
  endDate          DateTime?
  startDate        DateTime?
  artifacts        Artifact[]
  charterItems     CharterItem[]
  closingItems     ClosingItem[]
  eapItems         EAPItem[]
  objectives       Objective[]
  versions         ProjectVersion[]
  risks            Risk[]
  stakeholdersList Stakeholder[]
  statusReports    StatusReport[]
  budgetEntries    BudgetEntry[]
  decisions        Decision[]
}

model Objective {
  id        String   @id @default(uuid())
  projectId String
  text      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Stakeholder {
  id        String   @id @default(uuid())
  projectId String
  name      String
  role      String
  email     String?
  interest  String   @default("Médio")
  influence String   @default("Média")
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model CharterItem {
  id        String   @id @default(uuid())
  projectId String
  type      String
  text      String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ClosingItem {
  id        String   @id @default(uuid())
  projectId String
  type      String
  text      String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Artifact {
  id        String   @id @default(uuid())
  projectId String
  type      String
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectVersion {
  id           String   @id @default(uuid())
  projectId    String
  snapshotData Json
  label        String?
  artifactType String?
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model EAPItem {
  id          String   @id @default(uuid())
  projectId   String
  name        String
  description String?
  parentId    String?
  status      String   @default("PENDING")
  order       Float    @default(0)
  dependsOn   String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Risk {
  id          String   @id @default(uuid())
  projectId   String
  description String
  probability Int
  impact      Int
  status      String   @default("IDENTIFIED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  category    String   @default("Geral")
  contingency String?
  level       String   @default("Médio")
  mitigation  String?
  responsible String?
  title       String   @default("")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model StatusReport {
  id              String   @id @default(uuid())
  projectId       String
  reportDate      DateTime @default(now())
  nextSteps       String?
  createdAt       DateTime @default(now())
  accomplishments String?
  budgetSpent     Float?
  budgetStatus    String   @default("Em Dia")
  issues          String?
  overallStatus   String   @default("Verde")
  period          String
  progress        Float    @default(0)
  scheduleStatus  String   @default("No Prazo")
  scopeStatus     String   @default("No Escopo")
  updatedAt       DateTime @updatedAt
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model BudgetEntry {
  id          String   @id @default(uuid())
  projectId   String
  description String
  amount      Float
  type        String   @default("EXPENSE")
  category    String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  projectId String?
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Ticket {
  id            String   @id @default(uuid())
  userName      String
  userEmail     String?
  type          String   // BUG | IMPROVEMENT | FEATURE
  description   String
  screenshotUrl String?
  currentPath   String
  status        String   @default("Backlog")
  likes         String[] @default([])
  comments      Json     @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Decision {
  id          String   @id @default(uuid())
  projectId   String
  description String
  madeBy      String?
  context     String?
  status      String   @default("Registrada")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  projectId String
  userId    String?
  userName  String?  @default("Usuário Sistema")
  action    String
  entity    String
  entityId  String?
  field     String?
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())
}

// ── Intelligence Engine ──────────────────────────────────

enum IntelligenceCategory {
  BUDGET
  SCHEDULE
  RISK
  SCOPE
  QUALITY
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model IntelligenceRule {
  id               String               @id @default(uuid())
  key              String               @unique
  name             String
  description      String
  category         IntelligenceCategory
  formula          String
  defaultThreshold Float
  enabled          Boolean              @default(true)
  severity         AlertSeverity
  isSystem         Boolean              @default(true)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
}

model ProjectRuleOverride {
  id        String   @id @default(uuid())
  projectId String
  ruleKey   String
  threshold Float?
  enabled   Boolean?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, ruleKey])
}

model PredictiveAlert {
  id         String        @id @default(uuid())
  projectId  String
  ruleKey    String
  severity   AlertSeverity
  title      String
  message    String
  evidence   Json
  dismissed  Boolean       @default(false)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model ProjectHealthSnapshot {
  id             String   @id @default(uuid())
  projectId      String
  score          Int
  triggeredRules Json
  createdAt      DateTime @default(now())

  @@index([projectId, createdAt])
}

// ── Autopilot + Simulador ────────────────────────────────

enum AutopilotActionType {
  STATUS_REPORT_DRAFT
  RISK_ESCALATION
  BUDGET_ALERT
  SCHEDULE_ALERT
  STAGNATION_NUDGE
}

enum AutopilotActionStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

model AutopilotAction {
  id              String                @id @default(uuid())
  projectId       String
  type            AutopilotActionType
  status          AutopilotActionStatus @default(PENDING)
  triggeredByRule String
  draftData       Json
  reviewedAt      DateTime?
  reviewedBy      String?               @default("Usuário Sistema")
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([projectId, status])
  @@index([projectId, type, status])
}

model Scenario {
  id         String   @id @default(uuid())
  projectId  String
  label      String
  parameters Json
  result     Json
  narrative  String?
  radarData  Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId])
}
